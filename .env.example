# Base URL where your Cloudflare R2 media is served from.
# Use your R2 public bucket URL (https://pub-xxxx.r2.dev) or, better,
# a custom domain you've connected to the bucket (https://media.whamr.com).
# No trailing slash.
NEXT_PUBLIC_R2_BASE_URL=https://pub-REPLACE-ME.r2.dev

# The canonical site URL, used to build shareable deep links.
# In Vercel this is set automatically; locally it falls back to the request origin.
NEXT_PUBLIC_SITE_URL=https://whamr.vercel.app
